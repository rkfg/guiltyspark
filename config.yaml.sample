# Matrix Search Bot — Sample Configuration
# Copy to config.yaml and fill in your values.

bot:
  homeserver: "https://matrix.example.com"
  user_id: "@bot:matrix.example.com"
  access_token: "YOUR_ACCESS_TOKEN"
  storage_path: "./bot-data"

# E2EE support — required to receive messages in encrypted (Megolm) rooms.
# The bot creates a NEW device via password login and establishes a proper Olm account.
# Without login_password, E2EE may not work (see code for fallback).
e2ee:
  db_path: "./bot-data/e2ee.db"
  pickle_key: "change-me-to-a-random-string"
  # password for the bot account — used to create a new device with proper E2EE
  # leave empty to use existing access_token (E2EE may not work in encrypted rooms)
  login_password: ""

indexing:
  # Delayed LLM processing for images — daily time (hour 0-23, minute 0-59)
  # Default: 05:00. Text indexing happens immediately, LLM (VLM + embedding)
  # is deferred until this time.
  delayed_embed_hour: 5
  delayed_embed_minute: 0

llm:
  base_url: "https://your-llm-server.example.com/v1"
  api_key: "YOUR_LLM_API_KEY"
  embedding_model: "Qwen3 Embedding 8B"
  image_model: "Qwopus 3.5 4B [VLM]"
  image_prompt: |
    Подробно опишите содержимое изображения. Включите все видимые объекты,
    действия, контекст и весь читаемый текст с картинки. Отвечайте на русском
    языке, если текст на изображении на английском — процитируйте как есть
    и дополнительно переведите его на русский в скобках.
    Полученный текст должен быть достаточно краток
    и оптимизирован для дальнейшего поиска по нему.
    Без вступлений, комментариев, поэтической образности и заключений.

search:
  vector_dimensions: 4096
  result_limit: 5
  # Bleve analyzer for text/image_desc fields
  # Built-in: keyword, simple, standard, web, custom
  # Language-specific: ru, en, de, fr, es, it, pt, nl, no, da, sv, fi, hu, ar, tr, fa, hi, hi,
  # cjk (Chinese/Japanese/Korean), cs, hr, pl, ro, el, ga, gl, hy, id, in, eu
  # Note: language-specific analyzers require source code modifications
  analyzer: "ru"

image_processing:
  convert_binary: "convert"
  output_format: "jpg"
  output_quality: 85
  max_long_side: 1280
  cache_dir: "./cache/images"
  cache_ttl: 24h

retry:
  initial_delay: 1s
  max_delay: 300s
  multiplier: 2.0
  max_retries: -1
  timeout: 60s

# Link preview configuration
# Enabled: fetch preview (title, description) for URLs in messages
# Timeout: max time per URL request
# MaxURLs: max number of URLs to process per message
link_preview:
  enabled: true
  timeout: 5s
  max_urls: 5

history_scan:
  # Stop after N consecutive pages where all events are already indexed
  stale_pages_threshold: 3

rooms:
  # Room with history scan — bot will scan messages back to the specified date (DD.MM.YYYY)
  # "!roomid:server.org":
  #   history_scan_cutoff: "01.06.2025"
  # "#roomalias:server.org":
  #   history_scan_cutoff: "01.01.2025"
